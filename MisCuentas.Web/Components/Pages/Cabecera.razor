@using System.Globalization
@using MisCuentas.Domain.Models
@inject EstadoFecha _estadoFecha

<div class="flex-container">
    <div class = "flex-box">
        <label for="mes">Mes</label>
        <select class="filtro" @bind="mes">
            @for (int i = 1; i <= 12; i++)
            {
                <option value="@i">@CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)</option>
            }
        </select>
    </div>
    <div class="flex-box">
        <label for="ano">Año</label>
        <select class="filtro" @bind="ano">
            <option value="2024">2024</option>
            <option value="2025">2025</option>
            <option value="2026">2026</option>
        </select>
    </div>
    <div class="flex-box">
        <button type="button" id="filtrar" @onclick="filtrarFecha">Aplicar</button>
    </div>
</div>

@code {

    private int mes = DateTime.Now.Month;
    private int ano = DateTime.Now.Year;

    private void filtrarFecha()
    {
        _estadoFecha.CambiarEstado(mes, ano);
    }
}