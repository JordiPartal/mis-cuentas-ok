@using System.Globalization
@using MisCuentas.Domain.Interface
@using MisCuentas.Domain.Interface.Service
@using MisCuentas.Domain.Models
@inject EstadoFecha _estadoFecha
@inject ITransaccionService _transaccionService;
@implements IDisposable

<div id="flex-container">
    <h1>Transacciones del mes de @_mesTexto</h1>
    <table id="tabla-transacciones">
        <thead>
        <tr>
            @foreach (var cabecera in _cabecera)
            {
                <th>@cabecera</th>
            }
        </tr>
        </thead>
        @if (_transacciones == null)
        {
            <tbody>
            <tr>
                <td colspan="6">
                    <p>No hay transacciones para el mes seleccionado</p>
                </td>
            </tr>
            </tbody>
        }
        else
        {
            <tbody>
            @foreach (var transaccion in _transacciones.Skip(indiceInicio).Take(registrosVisibles))
            {
                <tr>
                    <td class="num">@transaccion.id?.ToString().PadLeft(2, '0').</td>
                    <td>@transaccion.fechaCargo.ToString("dd - MM - yyyy")</td>
                    <td>@transaccion.tipo</td>
                    
                    @if (@transaccion.tipo == "Nomina")
                    {
                        <td>@transaccion.concepto (tfr)</td>
                    }
                    else
                    {
                        <td>@transaccion.concepto</td>
                    }
                    
                    <td class="num">@transaccion._base.ToString("C")</td>
                    <td class="num">@transaccion.cuota.ToString("C")</td>
                    <td class="@EsNumero(transaccion.cantidad)">@transaccion.cantidad.ToString("C")</td>
                </tr>
            }
            </tbody>
        }
    </table>
    <div id="paginador">
        <img src="img/csv.png" alt="paginador" />
        <div id="acciones-paginador">
            <button class="btn-paginador"
                    disabled="@(indiceInicio == 0)"
                    @onclick="@AnteriorPagina">
                anterior
            </button>
            <button class="btn-paginador"
                    disabled="@(indiceInicio + registrosVisibles >= _transacciones?.Count)"
                    @onclick="@SiguientePagina">
                siguiente
            </button>
        </div>
    </div>
</div>

@code {
    int mes, ano;
    private int indiceInicio;
    private int registrosVisibles = 10;
    private string? _mesTexto;
    private string[] _cabecera = { "#id", "cargo", "categoria", "concepto", "sin imp.", "iva/irpf", "total" };
    
    private List<Transaccion> _transacciones;

    protected override async Task OnInitializedAsync()
    {
        _estadoFecha.AlCambiarEstado += RecargarDatos;
        await RecargarDatosAsync();
    }

    private void RecargarDatos()
    {
        indiceInicio = 0;
        _ = RecargarDatosAsync();
    }

    private async Task RecargarDatosAsync()
    {
        mes = _estadoFecha.Mes;
        ano = _estadoFecha.Anio;
        _mesTexto = CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(mes).ToUpper();

        _transacciones = await _transaccionService.ObtenerTransaccionAsync(mes, ano);
        
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _estadoFecha.AlCambiarEstado -= RecargarDatos;
    }
    
    private string EsNumero(decimal value)
    {
        return value <= 0 ? "num-negativo" : "num-positivo";
    }
    
    private void AnteriorPagina()
    {
        indiceInicio = Math.Max(0, indiceInicio - registrosVisibles); ;
    }

    private void SiguientePagina()
    {
        indiceInicio += registrosVisibles;
    }
}